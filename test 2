                local Keybind = {
                    Value = "",
                    Key = "",
                    Mode = KeybindData.Mode or "Toggle",
                    Picking = false
                }
                
                local KeyButton = Instances:Create("TextButton", {
                    Parent = Items["Toggle"].Instance,
                    FontFace = Library.Font,
                    TextColor3 = Library.Theme["Text"],
