                    for word in string.gmatch(query, "%S+") do
                        TableInsert(words, word)
                    end
                    
                    if #words > 0 then
                        for _, word in ipairs(words) do
                            if StringFind(name, word, 1, true) then
                                return true
                            end
                        end
                    end
                    
                    return false
                end

